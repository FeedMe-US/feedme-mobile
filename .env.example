# FeedMe Mobile Environment Variables
# Copy this file to .env and fill in the actual values

# Supabase Configuration (REQUIRED for authentication)
# Get these from your Supabase project dashboard: https://app.supabase.com
# Settings > API > Project URL and anon/public key
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# API Configuration (OPTIONAL)
# If not set, defaults to Railway production URL: https://build01-production.up.railway.app
# For local backend development, set to: http://YOUR_LOCAL_IP:8000
# EXPO_PUBLIC_API_URL=https://build01-production.up.railway.app
